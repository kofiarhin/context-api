# Copy to .env and adjust for your machine. Never commit a real .env file.

# Required
NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/context_api

# Optional
LOG_LEVEL=info

# Comma-separated allowlist. Leave empty to allow non-browser clients only.
# A wildcard is never applied by default.
CORS_ORIGINS=http://localhost:5173

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# GitHub gateway (/api/v1/github)
#
# Required in production; optional locally. If you set any one of these, all of
# them are validated, so a typo fails at startup rather than on first request.
# Never commit populated values.

# Numeric GitHub App ID from the app's settings page.
GITHUB_APP_ID=

# Numeric installation ID, visible in the installation URL.
GITHUB_INSTALLATION_ID=

# The App's PEM private key, Base64 encoded, on a single line:
#   base64 -w0 your-app.private-key.pem
# Decoded in memory only and never logged.
GITHUB_PRIVATE_KEY_BASE64=

# GitHub App installation scope. The approved current default is "all".
GITHUB_REPOSITORY_ACCESS=all

# Optional defense-in-depth restriction. Leave empty to preserve access to every
# repository visible to the installation, or provide comma-separated owner/repo
# values such as: kofiarhin/context-api,kofiarhin/ideahub
GITHUB_REPOSITORY_ALLOWLIST=

# Bearer secret required by every /api/v1/github route. Minimum 32 characters;
# generate with: openssl rand -hex 32
ZORO_GITHUB_API_KEY=
