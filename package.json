{
  "name": "context-api",
  "version": "1.0.0",
  "description": "CRUD API for structured, reusable user, engineering, project, workflow, glossary, and learning context.",
  "main": "src/server.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "data:extract": "node scripts/extract-ideas-hub-data.js",
    "seed": "node src/seeds/index.js",
    "seed:reset": "node src/seeds/index.js --reset"
  },
  "keywords": [
    "context",
    "express",
    "mongodb",
    "api"
  ],
  "author": "Kofi Arhin",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "mongoose": "^9.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.4.1",
    "prettier": "^3.7.4",
    "supertest": "^7.2.2"
  }
}
